generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PLAYER
}

enum GameType {
  TEXAS_HOLDEM
  OMAHA
  PINEAPPLE
  TEXAS_LAKRAN
  OMAHA_LAKRAN
  PREFERRED_2_CARDS
}

enum DayOfWeek {
  SUN
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

enum EventType {
  ORDINARY
  SPECIAL
}

enum EventFormat {
  IN_PERSON
  ONLINE
}

enum EventStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
  DONE
}

enum RegistrationStatus {
  CONFIRMED
  WAITLIST
  CANCELLED
}

enum PlayerSource {
  ATTENDEE
  UNREGISTERED_MEMBER
  GUEST
}

enum SettlementStatus {
  PENDING
  SENT
  CONFIRMED
}

enum CaseType {
  PRIMARY
  SECONDARY
}

model User {
  id            String      @id @default(cuid())
  fullName      String
  nickname      String      @unique
  phone         String      @unique
  role          Role        @default(PLAYER)
  isActive      Boolean     @default(true)
  favoriteGames GameType[]
  preferredDays DayOfWeek[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  hostedEvents        Event[]         @relation("HostedEvents")
  registrations       Registration[]
  eventPlayers        EventPlayer[]
  buyIns              BuyIn[]
  results             Result[]
  settlementsOwed     Settlement[]    @relation("SettlementFrom")
  settlementsReceived Settlement[]    @relation("SettlementTo")
  heldCases           PokerCase[]
  checklistItems      ChecklistItem[]
}

model Event {
  id                  String      @id @default(cuid())
  type                EventType
  format              EventFormat
  status              EventStatus @default(DRAFT)
  date                DateTime
  lastRoundTime       DateTime?
  registrationOpensAt DateTime
  maxSeats            Int         @default(9)
  onlineLink          String?
  onlinePassword      String?
  hostId              String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  host          User?           @relation("HostedEvents", fields: [hostId], references: [id])
  registrations Registration[]
  eventPlayers  EventPlayer[]
  buyIns        BuyIn[]
  results       Result[]
  settlements   Settlement[]
  checklist     ChecklistItem[]
  guests        Guest[]
}

model Registration {
  id           String             @id @default(cuid())
  eventId      String
  userId       String
  status       RegistrationStatus @default(CONFIRMED)
  position     Int
  registeredAt DateTime           @default(now())

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId],  references: [id])

  @@unique([eventId, userId])
}

model EventPlayer {
  id        String       @id @default(cuid())
  eventId   String
  userId    String?
  guestId   String?  @unique
  source    PlayerSource
  createdAt DateTime     @default(now())

  event Event  @relation(fields: [eventId], references: [id])
  user  User?  @relation(fields: [userId],  references: [id])
  guest Guest? @relation(fields: [guestId], references: [id])

  @@unique([eventId, userId])
  @@unique([eventId, guestId])
}

model Guest {
  id        String   @id @default(cuid())
  name      String
  eventId   String
  createdAt DateTime @default(now())

  event       Event        @relation(fields: [eventId], references: [id])
  eventPlayer EventPlayer?
  buyIn       BuyIn?
  result      Result?
}

model BuyIn {
  id        String   @id @default(cuid())
  eventId   String
  userId    String?
  guestId   String?  @unique
  count     Int      @default(1)
  createdAt DateTime @default(now())

  event Event  @relation(fields: [eventId], references: [id])
  user  User?  @relation(fields: [userId],  references: [id])
  guest Guest? @relation(fields: [guestId], references: [id])

  @@unique([eventId, userId])
}

model Result {
  id         String   @id @default(cuid())
  eventId    String
  userId     String?
  guestId    String?  @unique
  finalChips Int
  netNIS     Float
  createdAt  DateTime @default(now())

  event Event  @relation(fields: [eventId], references: [id])
  user  User?  @relation(fields: [userId],  references: [id])
  guest Guest? @relation(fields: [guestId], references: [id])

  @@unique([eventId, userId])
}

model Settlement {
  id            String           @id @default(cuid())
  eventId       String
  fromUserId    String?
  fromGuestId   String?
  fromGuestName String?
  toUserId      String?
  toGuestId     String?
  toGuestName   String?
  amountNIS     Float
  isGuestParty  Boolean          @default(false)
  status        SettlementStatus @default(PENDING)
  createdAt     DateTime         @default(now())

  event    Event  @relation(fields: [eventId],   references: [id])
  fromUser User?  @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser   User?  @relation("SettlementTo",   fields: [toUserId],   references: [id])
}

model PokerCase {
  id           String   @id @default(cuid())
  label        String
  type         CaseType
  heldByUserId String
  updatedAt    DateTime @updatedAt

  heldBy User @relation(fields: [heldByUserId], references: [id])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  eventId   String
  label     String
  isChecked Boolean  @default(false)
  addedById String
  createdAt DateTime @default(now())

  event   Event @relation(fields: [eventId],   references: [id])
  addedBy User  @relation(fields: [addedById], references: [id])
}